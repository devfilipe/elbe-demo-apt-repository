# Generated repo artifacts — match all subdirs (pool layout uses repo/pool/main/<x>/<pkg>/)
*.deb
*.dsc
*.tar.gz
*.tar.xz
*.tar.bz2
*.buildinfo
*.changes

# Generated APT index files
repo/Packages
repo/Packages.gz
repo/Sources
repo/Sources.gz
repo/Release
repo/Release.gpg
repo/InRelease
repo/repo-key.gpg

# GPG keys (generated at runtime, never commit)
keys/private.gpg
keys/public.asc

# GPG home used during signing
.gnupg/
